# Database
DATABASE_URL=postgresql://user:password@localhost:5432/arbitrance

# Auth
JWT_SECRET=your-256-bit-secret-here
JWT_REFRESH_SECRET=your-256-bit-refresh-secret-here
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Stripe (added later)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
WS_URL=ws://localhost:3002
NODE_ENV=development

# WalletConnect — get your project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID

# Crypto Payments — wallet addresses to receive USDC/USDT
NEXT_PUBLIC_PAYMENT_WALLET_ADDRESS=0xYourEvmWalletAddressHere
NEXT_PUBLIC_SOLANA_PAYMENT_WALLET=YourSolanaWalletAddressHere

# Default payment chain (base | polygon | arbitrum | ethereum | bsc | solana)
NEXT_PUBLIC_PAYMENT_CHAIN=base

# Internal API key — shared secret between Next.js and the price server (port 3001)
# Protects mutation endpoints (Magnus config, simulator resets, alert config)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=replace-with-64-char-hex-secret

# Crypto payment confirmation gate — requires on-chain verification before enabling
# Set to 'true' only after implementing viem/solana on-chain tx verification
CRYPTO_PAYMENTS_ENABLED=false
