{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": false,
    "incremental": false,
    "isolatedModules": false,
    "plugins": []
  },
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  },
  "include": ["scripts/**/*.ts", "server/**/*.ts", "lib/**/*.ts", "types/**/*.ts", "store/**/*.ts"]
}
